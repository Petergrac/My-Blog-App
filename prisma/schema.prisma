// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique // from Clerk
  username  String?
  email     String?
  country   String?
  bio       String?
  avatar    String?
  posts     Post[]
  comments  Comment[]
  likes     Like[]
  createdAt DateTime @default(now())

  @@index([username])
  @@index([email])
  @@index([createdAt])
}

model Post {
  id          String     @id @default(uuid())
  title       String
  content     String
  category    String
  coverImage  String
  description String
  state       PostState  @default(DRAFT)
  accessKey   String     @default(uuid())
  author      User       @relation(fields: [authorId], references: [id],onDelete: Cascade)
  authorId    String
  comments    Comment[]
  likes       Like[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([state, createdAt(sort: Desc)])
  @@index([state, updatedAt(sort: Desc)])
  @@index([category, state, createdAt(sort: Desc)])
  @@index([authorId, state, updatedAt(sort: Desc)])
  @@index([authorId, createdAt(sort: Desc)])
  @@index([accessKey])
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  post      Post     @relation(fields: [postId], references: [id],onDelete: Cascade)
  postId    String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String
  createdAt DateTime @default(now())

  @@index([postId, createdAt(sort: Desc)])
  @@index([authorId, createdAt(sort: Desc)])
}

model Like {
  id        String   @id @default(uuid())
  post      Post     @relation(fields: [postId], references: [id],onDelete: Cascade)
  postId    String
  user      User     @relation(fields: [userId], references: [id],onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@unique([postId, userId]) // 1 like per user per post
  @@index([userId, createdAt(sort: Desc)])
  @@index([postId, createdAt(sort: Desc)])
}

enum PostState {
  DRAFT
  PUBLISHED
}
