# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?apikey here" //Use this for prisma accelerate
DIRECT_DATABASE_URL="postgres://username:password@system:port?sslmode=require&pool=true" // use this for direct database access
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_publishable key here
CLERK_SECRET_KEY=sk_test_secret key here
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/onboarding
IMAGEKIT_PRIVATE_KEY='private_key here
IMAGEKIT_PUBLIC_KEY='public_key here
CLERK_WEBHOOK_SIGNING_SECRET=webhook secret
# NEXT_PRIVATE_DEBUG_CACHE=1